# Kisan Sahayak Server - Environment Variables Template

# App Settings
PORT=3000
NODE_ENV=development

# Security
# Generate a secure random string for JWT_SECRET (e.g., using `openssl rand -base64 32`)
JWT_SECRET=your_jwt_secret_here

# Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://admin:kisan_password@localhost:5435/kisan_db"

# Docker Credentials (used for docker-compose)
POSTGRES_USER=admin
POSTGRES_PASSWORD=kisan_password
POSTGRES_DB=kisan_db

# External APIs (Fill these once you integrate external services)
# WEATHER_API_KEY=your_weather_api_key
# SMS_GATEWAY_API_KEY=your_sms_gateway_key
